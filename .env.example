# =============================================================================
# ATLAS - Primary Environment Configuration
# =============================================================================
# This is the SINGLE SOURCE OF TRUTH for all credentials and tuning knobs.
# docker-compose.yml loads it via  env_file: .env.example
# Edit values here — they flow into every container automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Kafka Configuration (Single Broker - KRaft Mode)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=broker1:9092
KAFKA_TOPIC_RAW=raw-server-metrics
KAFKA_TOPIC_DLQ=raw-server-metrics-dlq
KAFKA_CONSUMER_GROUP=atlas-consumer-group

# Stability settings for Single Broker & Cluster
KAFKA_QUORUM_VOTERS=1@broker1:9093
KAFKA_REPLICATION_FACTOR=1
KAFKA_MIN_ISR=1
KAFKA_AUTO_CREATE_TOPICS=true



# -----------------------------------------------------------------------------
# PostgreSQL Configuration (analytics container hostname for external access)
# -----------------------------------------------------------------------------
POSTGRES_HOST=analytics
POSTGRES_PORT=5432
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secure_pwd
POSTGRES_DB=atlas_metadata

# -----------------------------------------------------------------------------
# ClickHouse Configuration (analytics container hostname for external access)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=analytics
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=atlas
CLICKHOUSE_PASSWORD=atlas_secure_pwd

# -----------------------------------------------------------------------------
# Spark Configuration
# -----------------------------------------------------------------------------
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_CHECKPOINT_DIR=/app/checkpoint

# -----------------------------------------------------------------------------
# Delta Lake Configuration
# -----------------------------------------------------------------------------
DELTA_LAKE_PATH=/app/delta/refined
DELTA_RAW_PATH=/app/delta/raw

# -----------------------------------------------------------------------------
# Telemetry Generator Configuration
# -----------------------------------------------------------------------------
DEVICE_COUNT=100000
SIMULATION_INTERVAL_SECONDS=300
READINGS_PER_HOUR=12

# -----------------------------------------------------------------------------
# Airflow Configuration (Optional)
# -----------------------------------------------------------------------------
# AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
# AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Analytics Loader Configuration
# -----------------------------------------------------------------------------
REFINED_DATA_PATH=/data/refined
BATCH_SIZE=10000
SCHEDULE_INTERVAL_SECONDS=3600
